# Web3 Comic Interface - Environment Variables
# Copy this file to .env and fill in your actual values

# WalletConnect Project ID - Get yours at https://cloud.walletconnect.com/
# This is REQUIRED for wallet connections to work
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Etherscan API Key - Get yours at https://etherscan.io/apis
# Used for fetching live gas prices
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Alchemy API Key (Optional) - Get yours at https://dashboard.alchemy.com/
# Provides better RPC connectivity
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# NFT Contract Address on Sepolia Testnet
# This is the deployed Nakamoto Chronicles NFT contract
VITE_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# App Configuration
VITE_APP_NAME=Nakamoto Chronicles
VITE_APP_DESCRIPTION=An interactive Web3 comic book experience
VITE_APP_URL=https://your-deployment-url.com

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SOUNDS=true
VITE_DEBUG_MODE=false
